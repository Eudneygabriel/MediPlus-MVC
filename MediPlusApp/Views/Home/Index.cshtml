@{
    ViewData["Title"] = "Painel de Controlo";
    var proximas = ViewBag.ProximasConsultas as List<MediPlusApp.Models.Marcacao>;
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="text-primary fw-bold text-uppercase mb-0">
                <i class="bi bi-grid-1x2-fill me-2"></i>Dashboard MediPlus
            </h2>
            <p class="text-muted small">Resumo operacional e fluxo de atendimento em tempo real.</p>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 border-start border-primary border-4" style="border-radius: 12px;">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 bg-primary-subtle text-primary rounded-circle p-3">
                            <i class="bi bi-people-fill fs-3"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-uppercase fw-bold text-muted mb-1" style="font-size: 0.7rem;">Total Pacientes</h6>
                            <h2 class="mb-0 fw-bold">@ViewBag.TotalPacientes</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 border-start border-success border-4" style="border-radius: 12px;">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 bg-success-subtle text-success rounded-circle p-3">
                            <i class="bi bi-stethoscope fs-3"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-uppercase fw-bold text-muted mb-1" style="font-size: 0.7rem;">Corpo Clínico</h6>
                            <h2 class="mb-0 fw-bold">@ViewBag.TotalMedicos</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 border-start border-warning border-4" style="border-radius: 12px;">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 bg-warning-subtle text-warning rounded-circle p-3">
                            <i class="bi bi-calendar-event-fill fs-3"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-uppercase fw-bold text-muted mb-1" style="font-size: 0.7rem;">Consultas Hoje</h6>
                            <h2 class="mb-0 fw-bold">@ViewBag.ConsultasHoje</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 15px;">
                <h5 class="fw-bold text-dark mb-4">Estado das Consultas</h5>
                <div style="height: 300px;">
                    <canvas id="chartStatus"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 15px; overflow: hidden;">
                <div class="card-header bg-white border-0 p-4 pb-0">
                    <h5 class="fw-bold text-dark mb-0">Próximos Atendimentos</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr class="small text-muted text-uppercase">
                                    <th class="ps-4">Horário</th>
                                    <th>Paciente</th>
                                    <th>Médico</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (proximas != null && proximas.Any())
                                {
                                    @foreach (var item in proximas)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle">
                                                    @item.DataHora.ToString("HH:mm")
                                                </span>
                                            </td>
                                            <td><div class="fw-bold">@item.Paciente?.Nome</div></td>
                                            <td><div class="small text-muted">@item.Medico?.Nome</div></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" class="text-center p-5 text-muted">
                                            <i class="bi bi-calendar-check d-block fs-1 opacity-25"></i>
                                            Sem consultas pendentes para hoje.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-white border-0 text-center pb-4">
                    <a asp-controller="Marcacoes" asp-action="Index" class="btn btn-outline-primary btn-sm rounded-pill px-4">
                        Ver Agenda Completa
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('chartStatus').getContext('2d');
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Realizadas', 'Faltas', 'Pendentes'],
                datasets: [{
                    data: [@ViewBag.Realizadas, @ViewBag.Faltas, @ViewBag.Pendentes],
                    backgroundColor: ['#198754', '#dc3545', '#ffc107'],
                    borderWidth: 0,
                    hoverOffset: 15
                }]
            },
            options: {
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } }
                },
                cutout: '75%'
            }
        });
    </script>
}