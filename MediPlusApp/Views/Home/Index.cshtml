@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="text-primary fw-bold text-uppercase">
                <i class="bi bi-speedometer2"></i> Painel de Gestão
            </h2>
            <p class="text-muted">Bem-vindo ao sistema MediPlusApp. Aqui está o resumo da sua clínica.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 border-start border-primary border-4">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 bg-primary text-white rounded-circle p-3">
                            <i class="bi bi-people-fill fs-3"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-uppercase fw-bold text-muted mb-1">Pacientes</h6>
                            <h2 class="mb-0">@ViewBag.TotalPacientes</h2>
                        </div>
                    </div>
                    <a asp-controller="Pacientes" asp-action="Index" class="btn btn-link p-0 mt-3 text-decoration-none">Ver todos →</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 border-start border-success border-4">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 bg-success text-white rounded-circle p-3">
                            <i class="bi bi-stethoscope fs-3"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-uppercase fw-bold text-muted mb-1">Médicos</h6>
                            <h2 class="mb-0">@ViewBag.TotalMedicos</h2>
                        </div>
                    </div>
                    <a asp-controller="Medicos" asp-action="Index" class="btn btn-link p-0 mt-3 text-decoration-none text-success">Ver corpo clínico →</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 border-start border-warning border-4">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 bg-warning text-white rounded-circle p-3">
                            <i class="bi bi-calendar-check fs-3"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-uppercase fw-bold text-muted mb-1">Hoje</h6>
                            <h2 class="mb-0">@ViewBag.ConsultasHoje</h2>
                        </div>
                    </div>
                    <a asp-controller="Marcacoes" asp-action="Index" class="btn btn-link p-0 mt-3 text-decoration-none text-warning">Ver agenda →</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-md-12">
            <div class="bg-white p-5 rounded shadow-sm text-center">
                <h3 class="fw-light">Pronto para começar o dia?</h3>
                <p class="text-muted">Utilize o menu superior para navegar entre as diferentes secções.</p>
                <img src="https://illustrations.popsy.co/blue/medical-care.svg" style="height: 200px;" alt="Saúde">
            </div>
        </div>
    </div>
</div>