@model MediPlusApp.Models.Medico

<div class="container mt-5 text-center">
    <div class="alert alert-danger shadow p-5">
        <i class="bi bi-exclamation-triangle-fill display-1"></i>
        <h2 class="mt-3">Tem a certeza?</h2>
        <p>Esta ação vai apagar permanentemente o médico <strong>@Model.Nome</strong> do sistema.</p>
        <form asp-action="Delete">
            <input type="hidden" asp-for="MedicoId" />
            <button type="submit" class="btn btn-danger btn-lg me-2">Sim, Eliminar</button>
            <a asp-action="Index" class="btn btn-secondary btn-lg">Cancelar</a>
        </form>
    </div>
</div>