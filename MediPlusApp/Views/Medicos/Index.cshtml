@model IEnumerable<MediPlusApp.Models.Medico>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary text-uppercase fw-bold">
            <i class="bi bi-stethoscope"></i> Corpo Clínico
        </h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle-fill"></i> Novo Médico
        </a>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Nome do Médico</th>
                        <th>Cédula</th>
                        <th>Especialidade</th>
                        <th>Email</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="ps-4 fw-bold text-primary">Dra. Carolina Cardoso</td>
                        <td>CP-77123</td>
                        <td>
                            <span class="badge bg-success">Pediatria</span>
                            <span class="badge bg-info">Medicina Geral</span>
                        </td>
                        <td>carolina.cardoso@mediplus.pt</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-info text-white shadow-sm" data-bs-toggle="modal" data-bs-target="#modalCarolina">
                                <i class="bi bi-person-lines-fill"></i> Bio
                            </button>
                        </td>
                    </tr>
                    <tr>
                        <td class="ps-4 fw-bold text-primary">Dr. Eudney Gabriel</td>
                        <td>CP-88234</td>
                        <td>
                            <span class="badge bg-danger">Cardiologia</span>
                            <span class="badge bg-secondary">Psiquiatria</span>
                        </td>
                        <td>eudney.gabriel@mediplus.pt</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-info text-white shadow-sm" data-bs-toggle="modal" data-bs-target="#modalEudney">
                                <i class="bi bi-person-lines-fill"></i> Bio
                            </button>
                        </td>
                    </tr>
                    <tr>
                        <td class="ps-4 fw-bold text-primary">Dra. Lara Lourenço</td>
                        <td>CP-99345</td>
                        <td>
                            <span class="badge bg-warning text-dark">Ginecologia</span>
                            <span class="badge bg-dark">Obstetrícia</span>
                        </td>
                        <td>lara.lourenco@mediplus.pt</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-info text-white shadow-sm" data-bs-toggle="modal" data-bs-target="#modalLara">
                                <i class="bi bi-person-lines-fill"></i> Bio
                            </button>
                        </td>
                    </tr>
                    <tr>
                        <td class="ps-4 fw-bold text-primary">Dr. Miguel Correia</td>
                        <td>CP-66456</td>
                        <td>
                            <span class="badge bg-primary">Ortopedia</span>
                            <span class="badge bg-success">Dermatologia</span>
                        </td>
                        <td>miguel.correia@mediplus.pt</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-info text-white shadow-sm" data-bs-toggle="modal" data-bs-target="#modalMiguel">
                                <i class="bi bi-person-lines-fill"></i> Bio
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalCarolina" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="bi bi-person-vcard"></i> Bio: Dra. Carolina Cardoso</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p><strong>Especialidades:</strong> Pediatria e Medicina Geral</p>
                <p class="text-muted">Especialista reconhecida pela sua abordagem lúdica na Pediatria e rigor na Medicina Geral. Foca-se no bem-estar integral da família, garantindo cuidados preventivos de excelência.</p>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalEudney" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-person-vcard"></i> Bio: Dr. Eudney Gabriel</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p><strong>Especialidades:</strong> Cardiologia e Psiquiatria</p>
                <p class="text-muted">Dedica-se à saúde do coração e da mente. Com vasta experiência em Cardiologia, integra conhecimentos de Psiquiatria para tratar patologias influenciadas pelo stress emocional.</p>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalLara" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title"><i class="bi bi-person-vcard"></i> Bio: Dra. Lara Lourenço</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p><strong>Especialidades:</strong> Ginecologia e Obstetrícia</p>
                <p class="text-muted">Especialista no acompanhamento personalizado da mulher. Da vigilância ginecológica ao apoio no parto, garante uma jornada de saúde segura e empática em todas as fases da vida.</p>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalMiguel" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-person-vcard"></i> Bio: Dr. Miguel Correia</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p><strong>Especialidades:</strong> Ortopedia e Dermatologia</p>
                <p class="text-muted">Especialista em medicina regenerativa. Trata desde lesões complexas na coluna (Ortopedia) até patologias cutâneas associadas (Dermatologia), visando a recuperação total da mobilidade.</p>
            </div>
        </div>
    </div>
</div>