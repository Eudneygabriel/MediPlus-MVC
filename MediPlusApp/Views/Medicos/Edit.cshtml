@model MediPlusApp.Models.Medico

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Editar Médico</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" enctype="multipart/form-data">
                        <input type="hidden" asp-for="MedicoId" />
                        <input type="hidden" asp-for="FotoPath" /> 

                        <div class="row">
                            <div class="col-md-4 text-center border-end">
                                <label class="form-label fw-bold d-block">Foto de Perfil</label>
                                
                                @if (!string.IsNullOrEmpty(Model.FotoPath))
                                {
                                    <img src="~/images/medicos/@Model.FotoPath" class="rounded-circle img-thumbnail mb-3 shadow-sm" style="width: 150px; height: 150px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-light rounded-circle border d-flex align-items-center justify-content-center text-secondary mb-3 mx-auto shadow-sm" style="width: 150px; height: 150px;">
                                        <i class="bi bi-person-fill display-1"></i>
                                    </div>
                                }
                                
                                <input type="file" name="FotoFile" class="form-control form-control-sm" accept="image/*" />
                                <small class="text-muted d-block mt-1">Selecione para alterar a foto</small>
                            </div>

                            <div class="col-md-8">
                                <div class="mb-3">
                                    <label asp-for="Nome" class="form-label fw-bold">Nome Profissional</label>
                                    <input asp-for="Nome" class="form-control" />
                                    <span asp-validation-for="Nome" class="text-danger"></span>
                                </div>

                                <div class="row mb-3">
                                    <div class="col">
                                        <label asp-for="Cedula" class="form-label fw-bold">Nº Cédula</label>
                                        <input asp-for="Cedula" class="form-control" />
                                        <span asp-validation-for="Cedula" class="text-danger"></span>
                                    </div>
                                    <div class="col">
                                        <label asp-for="EspecialidadeId" class="form-label fw-bold">Especialidade</label>
                                        <select asp-for="EspecialidadeId" class="form-select" asp-items="ViewBag.EspecialidadeId"></select>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label fw-bold">Email</label>
                                    <input asp-for="Email" type="email" class="form-control" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Bio" class="form-label fw-bold">Biografia Breve</label>
                                    <textarea asp-for="Bio" class="form-control" rows="3"></textarea>
                                    <span asp-validation-for="Bio" class="text-danger"></span>
                                </div>

                                <div class="d-grid gap-2 mt-4">
                                    <button type="submit" class="btn btn-primary shadow-sm">
                                        <i class="bi bi-check-circle me-1"></i> Guardar Alterações
                                    </button>
                                    <a asp-action="Index" class="btn btn-light border">Cancelar</a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}