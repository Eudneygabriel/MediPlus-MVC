@model MediPlusApp.Models.Medico

@{
    ViewData["Title"] = "Perfil do Médico";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow border-0 mb-4">
                <div class="card-header bg-info text-white text-center py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-person-vcard"></i> Ficha do Médico</h5>
                </div>
                <div class="card-body text-center">
                    <div class="mb-3">
                        @if (!string.IsNullOrEmpty(Model.FotoPath))
                        {
                            <img src="~/images/medicos/@Model.FotoPath" class="rounded-circle img-thumbnail shadow-sm" 
                                 style="width: 150px; height: 150px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="display-1 text-secondary"><i class="bi bi-person-circle"></i></div>
                        }
                    </div>

                    <h3 class="fw-bold text-dark mb-1">@Model.Nome</h3>
                    <p class="text-muted fw-bold small mb-3 text-uppercase">@Model.Especialidade?.Nome</p>
                    
                    <div class="text-start border-top pt-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small fw-bold">Cédula:</span>
                            <span class="fw-bold">@Model.Cedula</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small fw-bold">Email:</span>
                            <span class="small">@Model.Email</span>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <a asp-action="Edit" asp-route-id="@Model.MedicoId" class="btn btn-warning fw-bold text-dark">
                            <i class="bi bi-pencil-square"></i> Editar Dados
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-arrow-left"></i> Voltar à Lista
                        </a>
                    </div>
                </div>
            </div>

            <div class="card shadow border-0 bg-light">
                <div class="card-body">
                    <h6 class="fw-bold text-muted small text-uppercase mb-3">Resumo de Atividade</h6>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="small">Consultas Realizadas:</span>
                        <span class="badge bg-success">@Model.Marcacoes.Count(m => m.Estado == "Realizada")</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="small">Faltas Registadas:</span>
                        <span class="badge bg-danger">@Model.Marcacoes.Count(m => m.Estado == "Faltou")</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-clock-history"></i> Histórico de Consultas</h5>
                    <span class="badge bg-primary">@Model.Marcacoes.Count() Registos</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr class="small text-uppercase">
                                    <th class="ps-4">Data e Hora</th>
                                    <th>Paciente / Notas</th>
                                    <th class="text-center">Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Marcacoes != null && Model.Marcacoes.Any())
                                {
                                    @foreach (var m in Model.Marcacoes.OrderByDescending(x => x.DataHora))
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="fw-bold text-primary">@m.DataHora.ToString("dd/MM/yyyy")</div>
                                                <small class="text-muted fw-bold">@m.DataHora.ToString("HH:mm")</small>
                                            </td>
                                            <td>
                                                <div class="fw-bold text-dark">@m.Paciente?.Nome</div>
                                                <div class="small text-muted italic" style="max-width: 300px; font-size: 0.85rem;">
                                                    @(string.IsNullOrEmpty(m.Observacoes) ? "Sem observações." : m.Observacoes)
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                @if (m.Estado == "Realizada")
                                                {
                                                    <span class="badge bg-success-subtle text-success border border-success px-2">✓ @m.Estado</span>
                                                }
                                                else if (m.Estado == "Faltou")
                                                {
                                                    <span class="badge bg-danger-subtle text-danger border border-danger px-2">✕ @m.Estado</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning-subtle text-dark border border-warning px-2">@m.Estado</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" class="text-center py-5">
                                            <div class="text-muted">
                                                <i class="bi bi-folder-x display-4"></i>
                                                <p class="mt-2">Nenhuma consulta encontrada no histórico deste médico.</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>