@{
    ViewData["Title"] = "Nova Marcação";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-warning text-dark fw-bold uppercase">
                    <i class="bi bi-calendar-plus-fill"></i> Agendar Nova Consulta
                </div>
                <div class="card-body p-4">
                    <form>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Data e Hora</label>
                            <input type="datetime-local" class="form-control">
                        </div>

                        <div class="row mb-3">
                            <div class="col">
                                <label class="form-label fw-bold">Paciente</label>
                                <select class="form-select">
                                    <option selected>Selecione o paciente...</option>
                                    @* No futuro, isto virá da base de dados *@
                                </select>
                            </div>
                            <div class="col">
                                <label class="form-label fw-bold">Médico</label>
                                <select class="form-select">
                                    <option selected>Selecione o médico...</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Observações / Sintomas</label>
                            <textarea class="form-control" rows="3" placeholder="Ex: Paciente com febre há 2 dias..."></textarea>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Voltar
                            </a>
                            <button type="button" class="btn btn-warning fw-bold px-4 shadow-sm">
                                Confirmar Agendamento
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>