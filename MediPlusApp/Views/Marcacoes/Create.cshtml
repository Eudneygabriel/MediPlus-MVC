@model MediPlusApp.Models.Marcacao

@{
    ViewData["Title"] = "Nova Marcação";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-warning text-dark fw-bold text-uppercase">
                    <i class="bi bi-calendar-plus-fill"></i> Agendar Nova Consulta
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="DataHora" class="form-label fw-bold">Data e Hora</label>
                            <input asp-for="DataHora" type="datetime-local" class="form-control" />
                            <span asp-validation-for="DataHora" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-primary">1. O que o paciente necessita? (Especialidade)</label>
                            <select id="selectEspecialidade" class="form-select border-primary" asp-items="ViewBag.EspecialidadeId">
                                <option value="">--- Selecione a Especialidade ---</option>
                            </select>
                        </div>

                        <div class="row mb-3">
                            <div class="col">
                                <label asp-for="PacienteId" class="form-label fw-bold">Paciente</label>
                                <select asp-for="PacienteId" class="form-select" asp-items="ViewBag.PacienteId">
                                    <option value="">Selecione o paciente...</option>
                                </select>
                            </div>
                            <div class="col">
                                <label asp-for="MedicoId" class="form-label fw-bold">Médico Especialista</label>
                                <select asp-for="MedicoId" id="selectMedico" class="form-select" asp-items="ViewBag.MedicoId">
                                    <option value="">Aguardando especialidade...</option>
                                </select>
                                <span asp-validation-for="MedicoId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Observacoes" class="form-label fw-bold">Observações / Sintomas</label>
                            <textarea asp-for="Observacoes" class="form-control" rows="3" placeholder="Ex: Paciente com dor de dentes..."></textarea>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Voltar
                            </a>
                            <button type="submit" class="btn btn-warning fw-bold px-4 shadow-sm">
                                Confirmar Agendamento
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        // Lógica JS para filtrar médicos sem recarregar a página
        document.getElementById("selectEspecialidade").addEventListener("change", function () {
            var espId = this.value;
            var medicoSelect = document.getElementById("selectMedico");

            // Limpa a lista de médicos
            medicoSelect.innerHTML = '<option value="">A carregar...</option>';

            if (!espId) {
                medicoSelect.innerHTML = '<option value="">Selecione a especialidade primeiro</option>';
                return;
            }

            // Chama o Controller (o método que criámos antes)
            fetch('/Marcacoes/GetMedicosPorEspecialidade?especialidadeId=' + espId)
                .then(response => response.json())
                .then(data => {
                    medicoSelect.innerHTML = '<option value="">Selecione o médico...</option>';
                    data.forEach(m => {
                        var opt = document.createElement("option");
                        opt.value = m.id;
                        opt.innerHTML = m.nome;
                        medicoSelect.appendChild(opt);
                    });
                })
                .catch(error => {
                    console.error('Erro:', error);
                    medicoSelect.innerHTML = '<option value="">Erro ao carregar médicos</option>';
                });
        });
    </script>
}