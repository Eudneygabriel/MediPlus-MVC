@model IEnumerable<MediPlusApp.Models.Marcacao>

@{
    ViewData["Title"] = "Agenda de Consultas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary fw-bold mb-0" style="letter-spacing: -1px;">
                <i class="bi bi-calendar2-check-fill me-2"></i>AGENDA DE CONSULTAS
            </h2>
            <p class="text-muted small mb-0">Gestão operacional de atendimentos e presença de pacientes.</p>
        </div>
        <a asp-action="Create" class="btn btn-warning shadow-sm fw-bold px-4 py-2" style="border-radius: 10px;">
            <i class="bi bi-calendar-plus-fill me-2"></i>Nova Marcação
        </a>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light border-bottom">
                        <tr>
                            <th class="ps-4 py-3 text-secondary small fw-bold text-uppercase">Horário</th>
                            <th class="text-secondary small fw-bold text-uppercase">Paciente</th>
                            <th class="text-secondary small fw-bold text-uppercase">Equipa Médica</th>
                            <th class="text-secondary small fw-bold text-uppercase">Notas</th>
                            <th class="text-center text-secondary small fw-bold text-uppercase">Estado</th>
                            <th class="text-center text-secondary small fw-bold text-uppercase">Gestão</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderByDescending(x => x.DataHora))
                        {
                            <tr class="@(item.Estado == "Faltou" ? "table-light opacity-75" : "")">
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@item.DataHora.ToString("dd/MM/yyyy")</div>
                                    <span class="badge bg-white text-primary border border-primary-subtle px-2 shadow-sm">
                                        <i class="bi bi-clock me-1"></i> @item.DataHora.ToString("HH:mm")
                                    </span>
                                </td>
                                <td>
                                    <div class="fw-bold text-primary mb-0">@item.Paciente?.Nome</div>
                                    <small class="text-muted" style="font-size: 0.75rem;">ID: #@item.PacienteId</small>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-info-subtle rounded-circle p-2 me-2 text-info d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                                            <i class="bi bi-person-badge-fill"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark mb-0">@item.Medico?.Nome</div>
                                            <div class="text-info fw-semibold text-uppercase" style="font-size: 0.65rem;">@item.Medico?.Especialidade?.Nome</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="text-muted small text-truncate" style="max-width: 150px;" title="@item.Observacoes">
                                        @(string.IsNullOrEmpty(item.Observacoes) ? "—" : item.Observacoes)
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (item.Estado == "Realizada")
                                    {
                                        <span class="badge rounded-pill bg-success-subtle text-success border border-success px-3 py-2">
                                            <i class="bi bi-check-circle-fill me-1"></i> Concluída
                                        </span>
                                    }
                                    else if (item.Estado == "Faltou")
                                    {
                                        <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger px-3 py-2">
                                            <i class="bi bi-x-circle-fill me-1"></i> Faltou
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-warning-subtle text-warning border border-warning px-3 py-2">
                                            <i class="bi bi-hourglass-split me-1"></i> Pendente
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (item.Estado == "Confirmada")
                                    {
                                        <div class="btn-group shadow-sm border rounded">
                                            <form asp-action="Concluir" asp-route-id="@item.MarcacaoId" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-white text-success fw-bold border-end px-3" title="Concluir">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                            </form>
                                            <form asp-action="MarcarFalta" asp-route-id="@item.MarcacaoId" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-white text-danger fw-bold px-3" title="Marcar Falta">
                                                    <i class="bi bi-person-x"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small fst-italic"><i class="bi bi-archive-fill me-1"></i>Finalizada</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover { background-color: #f8faff !important; transition: 0.2s; }
    .btn-white { background: white; border: none; }
    .btn-white:hover { background: #f8f9fa; }
</style>