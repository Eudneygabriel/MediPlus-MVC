@model IEnumerable<MediPlusApp.Models.Marcacao>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold text-uppercase">
            <i class="bi bi-calendar-event"></i> Agenda de Consultas
        </h2>
        <a asp-action="Create" class="btn btn-warning shadow-sm fw-bold">
            <i class="bi bi-calendar-plus"></i> Nova Marcação
        </a>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card shadow border-0">
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Data e Hora</th>
                                <th>Paciente</th>
                                <th>Médico</th>
                                <th>Observações</th>
                                <th class="text-center">Estado / Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center p-4 text-muted">
                                        Não existem marcações agendadas.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <span class="badge bg-primary px-3 py-2">
                                                @item.DataHora.ToString("dd/MM/yyyy - HH:mm")
                                            </span>
                                        </td>
                                        <td class="fw-bold">
                                            @item.Paciente?.Nome
                                        </td>
                                        <td>
                                            @item.Medico?.Nome
                                        </td>
                                        <td class="text-muted small">
                                            @item.Observacoes
                                        </td>
                                        <td class="text-center">
                                            @if (item.Estado == "Confirmada")
                                            {
                                                <form asp-action="Concluir" asp-route-id="@item.MarcacaoId" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-success fw-bold shadow-sm">
                                                        <i class="bi bi-check-circle"></i> Concluir
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill bg-success-subtle text-success border border-success px-3">
                                                    <i class="bi bi-check-all"></i> Realizada
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>