@model IEnumerable<MediPlusApp.Models.Marcacao>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold text-uppercase">
            <i class="bi bi-calendar-event"></i> Agenda de Consultas
        </h2>
        <a asp-action="Create" class="btn btn-warning shadow-sm fw-bold">
            <i class="bi bi-calendar-plus"></i> Nova Marcação
        </a>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card shadow border-0">
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Data e Hora</th>
                                <th>Paciente</th>
                                <th>Médico</th>
                                <th>Observações</th>
                                <th class="text-center">Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @* Exemplo de como vai aparecer quando houver dados *@
                            <tr>
                                <td class="ps-4">
                                    <span class="badge bg-primary px-3 py-2">18/03/2026 - 14:30</span>
                                </td>
                                <td class="fw-bold">A carregar...</td>
                                <td>A carregar...</td>
                                <td class="text-muted small">Consulta de rotina</td>
                                <td class="text-center">
                                    <span class="badge rounded-pill bg-success-subtle text-success border border-success">Confirmada</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>