@model IEnumerable<MediPlusApp.Models.Especialidade>

@{
    ViewData["Title"] = "Especialidades Médicas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary text-uppercase fw-bold">
            <i class="bi bi-star-fill"></i> Especialidades
        </h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle"></i> Nova Especialidade
        </a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th class="ps-4">ID</th>
                                <th>Designação / Nome</th>
                                <th class="text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4 text-muted">#@item.EspecialidadeId</td>
                                        <td class="fw-bold">@item.Nome</td>
                                        <td class="text-center">
                                            <div class="btn-group">
                                                <a asp-action="Edit" asp-route-id="@item.EspecialidadeId" class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@item.EspecialidadeId" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center py-5">
                                        <i class="bi bi-search display-4 text-muted"></i>
                                        <p class="text-muted mt-2">Nenhuma especialidade registada.</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-light border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <i class="bi bi-info-circle text-primary display-6"></i>
                    <h5 class="mt-3 fw-bold">Gestão de Unidades</h5>
                    <p class="small text-muted">Aqui pode definir as áreas médicas disponíveis na MediPlus para associar aos médicos.</p>
                    <hr>
                    <p class="small mb-0"><strong>Dica:</strong> Estas especialidades aparecem no momento de agendar novas consultas.</p>
                </div>
            </div>
        </div>
    </div>
</div>