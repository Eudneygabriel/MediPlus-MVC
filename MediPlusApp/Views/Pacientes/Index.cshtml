@model IEnumerable<MediPlusApp.Models.Paciente>

@{
    ViewData["Title"] = "Gestão de Pacientes";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary text-uppercase fw-bold">
            <i class="bi bi-person-vcard-fill"></i> Lista de Pacientes
        </h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-person-plus-fill"></i> Registar Novo
        </a>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Nome</th>
                            <th>SNS</th>
                            <th>Email</th>
                            <th>Telemóvel</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold">@item.Nome</td>
                                    <td>@item.SNS</td>
                                    <td>@item.Email</td>
                                    <td>@item.Telemovel</td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Edit" asp-route-id="@item.PacienteId" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                            <a asp-action="Details" asp-route-id="@item.PacienteId" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                                            <a asp-action="Delete" asp-route-id="@item.PacienteId" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <div class="spinner-grow text-primary mb-3" role="status"></div>
                                    <p class="text-muted h5">A aguardar ligação com a base de dados...</p>
                                    <small class="text-secondary">Os dados do diagrama aparecerão aqui em breve.</small>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>