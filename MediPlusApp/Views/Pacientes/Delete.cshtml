@model MediPlusApp.Models.Paciente

@{
    ViewData["Title"] = "Eliminar Paciente";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-danger text-white text-center py-3">
                    <h3 class="mb-0"><i class="bi bi-exclamation-octagon-fill"></i> ZONA DE PERIGO</h3>
                </div>
                <div class="card-body p-4 text-center">
                    <p class="fs-5">Estás prestes a eliminar permanentemente o paciente:</p>
                    <h2 class="text-dark fw-bold mb-4">@Model.Nome</h2>

                    @if (Model.Marcacoes != null && Model.Marcacoes.Any())
                    {
                        <div class="alert alert-warning border-warning">
                            <i class="bi bi-info-circle-fill"></i> <strong>Atenção:</strong> 
                            Este paciente tem <strong>@Model.Marcacoes.Count()</strong> consultas no histórico. 
                            Ao eliminá-lo, todos esses registos serão perdidos para sempre!
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-secondary">
                            Este paciente não tem consultas registadas. A remoção é segura.
                        </div>
                    }

                    <hr />

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="PacienteId" />
                        
                        <div class="d-grid gap-2 d-md-block">
                            <button type="submit" class="btn btn-danger btn-lg px-5 shadow-sm">
                                <i class="bi bi-trash3"></i> Sim, Eliminar Tudo
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5">
                                Cancelar
                            </a>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-light text-muted small text-center">
                    ID do Paciente: #@Model.PacienteId
                </div>
            </div>
        </div>
    </div>
</div>